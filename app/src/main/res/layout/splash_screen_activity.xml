<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottie_splash"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:lottie_rawRes="@raw/splashscreen"
        android:padding="36dp"
        app:lottie_autoPlay="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <TextView
        android:id="@+id/name_app"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dictionary App"
        android:fontFamily="@font/font"
        android:textColor="@color/purple_700"
        android:textStyle="bold"
        android:textSize="28sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lottie_splash"
        app:layout_constraintVertical_chainStyle="packed"
        />

    <TextView
        android:id="@+id/by_elshod_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="by Mr.ElshodDev"
        android:textColor="@color/purple_500"
        android:fontFamily="@font/font"
        android:layout_marginTop="4dp"
        app:layout_constraintEnd_toEndOf="@id/name_app"
        app:layout_constraintTop_toBottomOf="@id/name_app"
        app:layout_constraintHorizontal_chainStyle="packed" />
</androidx.constraintlayout.widget.ConstraintLayout>